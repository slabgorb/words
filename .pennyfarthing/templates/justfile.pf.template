# Pennyfarthing framework recipes — auto-generated by pf init
# DO NOT EDIT — overwritten on every pf init
# Add project recipes to ./justfile instead
#
# Requires `root := justfile_directory()` in the parent justfile.

# Run pf CLI command via the project-local shim
# Usage: just pf doctor, just pf sprint status, just pf settings show
pf *args:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ -z "{{args}}" ]]; then
        "{{root}}/.pennyfarthing/bin/pf" --help || true
    else
        "{{root}}/.pennyfarthing/bin/pf" {{args}}
    fi

# Start Frame server (idempotent — reuses existing instance)
frame:
    just pf launch frame

# Stop Frame server
frame-stop:
    just pf launch stop

# Launch TUI panel viewer (starts Frame if needed)
tui:
    just pf launch tui --foreground

# Launch Claude with OTEL pre-configured for Frame
claude:
    #!/usr/bin/env bash
    set -euo pipefail

    project_dir="{{root}}"
    PORT=""

    port_file="$project_dir/.frame-port"
    if [[ -f "$port_file" ]]; then
        candidate=$(cat "$port_file" 2>/dev/null)
        if [[ "$candidate" =~ ^[0-9]+$ ]]; then
            if (echo >/dev/tcp/localhost/"$candidate") 2>/dev/null; then
                PORT="$candidate"
            fi
        fi
    fi

    if [[ -n "$PORT" ]]; then
        echo "[just claude] OTEL configured → http://localhost:$PORT" >&2
        export CLAUDE_CODE_ENABLE_TELEMETRY="1"
        export OTEL_EXPORTER_OTLP_PROTOCOL="http/json"
        export OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:$PORT"
        export OTEL_LOGS_EXPORTER="otlp"
        export OTEL_METRICS_EXPORTER="otlp"
    else
        echo "[just claude] No Frame running — launching without OTEL" >&2
        echo "[just claude] Start one first: just frame" >&2
    fi

    exec claude

# Start Pennyfarthing session (Claude Code + TUI in tmux split panes)
# Usage: just start [layout] [split]
#   layout: bottom (default), top, right, left — where to place the TUI
#   split:  TUI pane size % (default: 50 for top/bottom, 35 for right/left)
start layout="bottom" split="":
    exec "{{root}}/start-session" "{{layout}}" {{split}}

# Start Pennyfarthing session for a specific project directory
start-at layout="bottom" split="" dir=invocation_directory():
    exec "{{root}}/start-session" "{{layout}}" {{split}} "{{dir}}"
