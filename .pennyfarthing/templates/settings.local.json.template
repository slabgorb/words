{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash",
      "Bash(claude:*)",
      "Bash(date:*)",
      "Bash(mkdir:*)",
      "Edit(.claude/**)",
      "Edit(.pennyfarthing/**)",
      "Edit(sprint/**)",
      "Edit(.session/**)",
      "Edit(results/**)",
      "Write(.claude/**)",
      "Write(.pennyfarthing/**)",
      "Write(sprint/**)",
      "Write(.session/**)",
      "Write(results/**)",
      "Skill(pf-sm)",
      "Skill(pf-tea)",
      "Skill(pf-dev)",
      "Skill(pf-reviewer)",
      "Skill(pf-solo)",
      "Skill(pf-benchmark)",
      "Skill(pf-benchmark-control)",
      "Skill(pf-judge)",
      "Skill(pf-finalize-run)"
    ]
  },
  "context_budget": {
    "warning_threshold": 70,
    "critical_threshold": 85,
    "max_tokens": 200000
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"$CLAUDE_PROJECT_DIR/node_modules/@pennyfarthing/core/pennyfarthing-dist\" pf hooks session-start"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.pennyfarthing/project/hooks/setup-env.sh"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.pennyfarthing/project/hooks/auto-load-sm.sh"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"$CLAUDE_PROJECT_DIR/node_modules/@pennyfarthing/core/pennyfarthing-dist\" pf prime"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"$CLAUDE_PROJECT_DIR/node_modules/@pennyfarthing/core/pennyfarthing-dist\" pf hooks session-stop"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"$CLAUDE_PROJECT_DIR/node_modules/@pennyfarthing/core/pennyfarthing-dist\" pf hooks sprint-yaml"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"$CLAUDE_PROJECT_DIR/node_modules/@pennyfarthing/core/pennyfarthing-dist\" pf hooks pre-edit-check"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"$CLAUDE_PROJECT_DIR/node_modules/@pennyfarthing/core/pennyfarthing-dist\" pf hooks schema-validation"
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|Task",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"$CLAUDE_PROJECT_DIR/node_modules/@pennyfarthing/core/pennyfarthing-dist\" pf hooks context-warning"
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|Task",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"$CLAUDE_PROJECT_DIR/node_modules/@pennyfarthing/core/pennyfarthing-dist\" pf hooks context-breaker"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"$CLAUDE_PROJECT_DIR/node_modules/@pennyfarthing/core/pennyfarthing-dist\" pf hooks cyclist-pretooluse"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "uv run --project \"$CLAUDE_PROJECT_DIR/node_modules/@pennyfarthing/core/pennyfarthing-dist\" pf hooks statusline"
  }
}
